{
  "name": "config-builder-starter",
  "description": "Visual config generator for Prettier, ESLint, and .gitignore. Pick a framework preset, tweak the options, and export production-ready config files in JSON, YAML, or JS format — no manual setup required",
  "author": "@jirateep12z",
  "license": "MIT",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint \"src/**/*.{js,ts,jsx,tsx,json,css,html}\"",
    "lint:fix": "eslint \"src/**/*.{js,ts,jsx,tsx,json,css,html}\" --fix",
    "format": "prettier --write \"src/**/*.{js,ts,jsx,tsx,json,css,html}\""
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/inter": "^5.3.0",
    "@fontsource-variable/noto-sans-thai": "^5.3.0",
    "@tailwindcss/vite": "^4.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "js-yaml": "^5.2.2",
    "lucide-react": "^1.26.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.5",
    "react": "^19.2.8",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.8",
    "react-resizable-panels": "^4.12.2",
    "recharts": "^3.10.0",
    "shadcn": "^4.14.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.9.6",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5"
  }
}
